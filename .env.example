# X Tweet Helper — environment configuration
# Copy to .env.local and fill in values. Never commit real secrets.

# App (use LAN IP when using phone — see README §6)
NODE_ENV=development
APP_URL=http://localhost:3000

# ── X (Twitter) OAuth 2.0 ──────────────────────────────────────
# Create an app at https://developer.x.com with OAuth 2.0 enabled.
# Scopes required: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/auth/x/callback

# ── LLM providers (any subset; UI enables those with keys) ─────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=          # Gemini API (Google AI Studio) — optional if using Antigravity bridge below
XAI_API_KEY=             # Grok (https://api.x.ai/v1)

# Antigravity local bridge — uses Antigravity.app + subscription (no API key).
# 1. Keep Antigravity.app open with at least one workspace
# 1. Open Antigravity IDE with a workspace folder
# 2. npm run antigravity:proxy
ANTIGRAVITY_PROXY_URL=http://127.0.0.1:4000
# ANTIGRAVITY_PROXY_ENABLED=true   # force Antigravity when both proxy URL and GOOGLE_API_KEY are set

# Legacy Gemini CLI OAuth (deprecated June 2026 for individual Pro accounts)
# GEMINI_CLI_PROXY_URL=http://127.0.0.1:8317

# ── Infrastructure ─────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/twitter_helper

# 32-byte (64 hex char) key for encrypting tokens & provider keys at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Background jobs ────────────────────────────────────────────
# Required only when using serverless cron (Vercel). Callers must send
# `Authorization: Bearer <CRON_SECRET>`. Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Observability (optional) ───────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
