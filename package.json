{
  "name": "x-tweet-helper",
  "version": "0.1.0",
  "description": "Self-hosted X (Twitter) growth workspace — AI tweets, threads, blogs, analytics, and free Open-in-X posting.",
  "repository": {
    "type": "git",
    "url": "https://github.com/atulmishra1996/x-tweet-helper.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gemini:proxy": "gemini-cli-api-wrapper --port 8317",
    "postinstall": "node scripts/patch-open-antigravity.mjs",
    "antigravity:proxy": "node scripts/patch-open-antigravity.mjs && PORT=4000 HOST=127.0.0.1 tsx node_modules/open-antigravity/src/index.ts",
    "dev:all": "concurrently \"npm run antigravity:proxy\" \"npm run dev\"",
    "dev:lan": "node scripts/dev-lan.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.209",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@google/gemini-cli": "^0.47.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "gemini-cli-api-wrapper": "^0.1.0",
    "open-antigravity": "github:iHYZ/open-antigravity",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
